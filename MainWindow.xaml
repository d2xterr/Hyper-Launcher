<Window x:Class="MinecraftLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinecraftLauncher"
        mc:Ignorable="d"
        Title="Minecraft Launcher" 
        Height="850" 
        Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundDarker">#050505</SolidColorBrush>
        <SolidColorBrush x:Key="BackgroundDark">#0A0A0A</SolidColorBrush>
        <SolidColorBrush x:Key="BackgroundMedium">#121212</SolidColorBrush>
        <SolidColorBrush x:Key="BackgroundLight">#1E1E1E</SolidColorBrush>
        <SolidColorBrush x:Key="BackgroundLighter">#2D2D2D</SolidColorBrush>


        <SolidColorBrush x:Key="AccentPrimary">#E0E0E0</SolidColorBrush>
        <SolidColorBrush x:Key="AccentSecondary">#B0B0B0</SolidColorBrush>
        <SolidColorBrush x:Key="AccentTertiary">#808080</SolidColorBrush>

        <SolidColorBrush x:Key="TextPrimary">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondary">#B0B0B0</SolidColorBrush>
        <SolidColorBrush x:Key="TextMuted">#606060</SolidColorBrush>

        <!-- Border colors -->
        <SolidColorBrush x:Key="BorderColor">#2A2A2A</SolidColorBrush>
        <SolidColorBrush x:Key="BorderLight">#3A3A3A</SolidColorBrush>


        <SolidColorBrush x:Key="HoverBackground">#2A2A2A</SolidColorBrush>
        <SolidColorBrush x:Key="PressedBackground">#353535</SolidColorBrush>
        <SolidColorBrush x:Key="DragOverBackground">#2A2A2A</SolidColorBrush>

  
        <Style x:Key="BlackScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="#1A1A1A" CornerRadius="4"/>

                            <Track x:Name="PART_Track" 
                                   Grid.Row="0" 
                                   Orientation="{TemplateBinding Orientation}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="#404040" 
                                                        CornerRadius="4"
                                                        BorderThickness="0"
                                                        Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

     
        <Style x:Key="BlackScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="PanningMode" Value="Both"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Row="0" Grid.Column="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    CanHorizontallyScroll="True"
                                                    CanVerticallyScroll="True"/>

                    
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                      Grid.Row="0" Grid.Column="1"
                                      Style="{StaticResource BlackScrollBar}"
                                      Orientation="Vertical"
                                      Minimum="0"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="BlackListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer x:Name="ScrollViewer"
                                      Style="{StaticResource BlackScrollViewer}"
                                      Padding="{TemplateBinding Padding}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

     
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PressedBackground}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundLight}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

       
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PressedBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource AccentTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource BackgroundDark}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSecondary}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

       
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentTertiary}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentSecondary}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

   
        <Style x:Key="VersionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Margin="0,2">
                            <ContentPresenter HorizontalAlignment="Left" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundLighter}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

      
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentSecondary}"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2"
                                    Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Converter={x:Static local:PercentageToWidthConverter.Instance}}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

 
    <Border x:Name="MainBorder"
            Background="{StaticResource BackgroundDark}"
            CornerRadius="15"
            Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" 
                            ShadowDepth="0" 
                            Opacity="0.5"
                            Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Border Grid.Column="0"
                    Background="{StaticResource BackgroundDarker}"
                    CornerRadius="15,0,0,15">
                <Grid Margin="0,30,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                  
                    <StackPanel Grid.Row="0" Margin="0,0,0,30" HorizontalAlignment="Center">
                       
                        <Border Width="120" 
                                Height="120" 
                                Background="Transparent"
                                CornerRadius="20"
                                BorderBrush="{StaticResource AccentTertiary}"
                                BorderThickness="2"
                                Margin="0,0,0,10">
                            <Image x:Name="SidebarBlockImage"
                                   Source="/Resources/block.png" 
                                   Stretch="Uniform"
                                   Width="100"
                                   Height="100"/>
                        </Border>

                   
                        <TextBlock Text="Hyper"
                                  Foreground="{StaticResource TextPrimary}"
                                  FontSize="16"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="LAUNCHER"
                                  Foreground="{StaticResource TextMuted}"
                                  FontSize="11"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>

                 
                    <StackPanel Grid.Row="1">
                        <Button x:Name="HomeButton"
                               Style="{StaticResource SidebarButton}"
                               Content="  🏠 HOME"
                               Tag="Selected"
                               Click="NavigateToHome"/>
                        <Button x:Name="VersionsButton"
                               Style="{StaticResource SidebarButton}"
                               Content="  📦 VERSIONS"
                               Click="NavigateToVersions"/>
                        <Button x:Name="SettingsButton"
                               Style="{StaticResource SidebarButton}"
                               Content="  ⚙️ SETTINGS"
                               Click="NavigateToSettings"/>
                    </StackPanel>

                    
                    <StackPanel Grid.Row="2" Margin="25,0,25,30">
                        <TextBlock Text="BUILDS FOLDER"
                                  Foreground="{StaticResource TextMuted}"
                                  FontSize="9"
                                  Margin="0,0,0,5"/>
                        <TextBlock Text="📁 Builds/"
                                  Foreground="{StaticResource AccentSecondary}"
                                  FontSize="12"
                                  FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

         
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

               
                <Border Grid.Row="0"
                        Background="{StaticResource BackgroundMedium}"
                        CornerRadius="0,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="PageTitle"
                                  Text="HOME"
                                  Foreground="{StaticResource TextPrimary}"
                                  FontSize="16"
                                  FontWeight="Bold"
                                  Margin="30,0"
                                  VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" 
                                   Orientation="Horizontal" 
                                   HorizontalAlignment="Right"
                                   Margin="0,0,15,0">
                           
                            <Button Content="─" 
                                    Style="{StaticResource WindowControlButton}"
                                    Click="Minimize_Click"/>
                            <Button Content="✕" 
                                    Style="{StaticResource WindowControlButton}"
                                    Click="Close_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

               
                <Grid Grid.Row="1" Margin="30">
                   
                    <Grid x:Name="HomePage" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                     
                        <Border Grid.Row="0"
                                CornerRadius="12"
                                Margin="0,0,0,25"
                                Background="{StaticResource BackgroundMedium}">
                            <Grid>
                             
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Image x:Name="BannerBackgroundImage"
                                           Source="/Resources/banner.jpg"
                                           Stretch="UniformToFill"
                                           Opacity="0.25"/>
                                </Border>

                                <Grid Margin="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="WELCOME BACK"
                                                 Foreground="{StaticResource TextSecondary}"
                                                 FontSize="12"
                                                 Margin="0,0,0,5"/>
                                        <TextBlock x:Name="HomeUsernameDisplay"
                                                 Text="Player"
                                                 Foreground="{StaticResource TextPrimary}"
                                                 FontSize="36"
                                                 FontWeight="Light"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                       
                        <Border Grid.Row="1"
                                Background="{StaticResource BackgroundMedium}"
                                CornerRadius="12"
                                Padding="25"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="SELECT VERSION TO PLAY"
                                         Foreground="{StaticResource TextMuted}"
                                         FontSize="11"
                                         Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                  
                                    <Border Grid.Column="0"
                                            Background="#1E1E1E"
                                            CornerRadius="8"
                                            BorderBrush="#2A2A2A"
                                            BorderThickness="1"
                                            Height="120"
                                            Margin="0,0,15,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                  
                                            <Border Grid.Row="0"
                                                    Background="#0A0A0A"
                                                    CornerRadius="8,8,0,0"
                                                    Padding="12,8"
                                                    BorderBrush="#2A2A2A"
                                                    BorderThickness="0,0,0,1">
                                                <TextBlock Text="Available Versions"
                                                         Foreground="#B0B0B0"
                                                         FontSize="11"
                                                         FontWeight="SemiBold"/>
                                            </Border>

                                            <ListBox x:Name="HomeVersionListBox"
                                                    Grid.Row="1"
                                                    Style="{StaticResource BlackListBox}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    ItemContainerStyle="{StaticResource VersionItemStyle}"
                                                    SelectionChanged="HomeVersionListBox_SelectionChanged"
                                                    Margin="0,2,0,2">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Icon}" Margin="0,0,8,0" Foreground="{StaticResource AccentSecondary}"/>
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>


                                    <Button Grid.Column="1"
                                           Content="PLAY"
                                           Style="{StaticResource AccentButton}"
                                           Width="120"
                                           Height="NaN"
                                           Click="HomePlayButton_Click" Margin="0,10,0,0"/>
                                </Grid>

                             
                                <TextBlock x:Name="SelectedVersionText"
                                         Text="No version selected"
                                         Foreground="{StaticResource TextSecondary}"
                                         FontSize="12"
                                         Margin="0,10,0,0"
                                         HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                     
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                      
                            <Border Grid.Column="0"
                                    Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="25"
                                    Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="STABLE BUILDS"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="11"
                                             Margin="0,0,0,15"/>
                                    <TextBlock x:Name="StableBuildsCount"
                                             Text="0"
                                             Foreground="{StaticResource AccentPrimary}"
                                             FontSize="42"
                                             FontWeight="Light"/>
                                    <TextBlock Text="versions available"
                                             Foreground="{StaticResource TextSecondary}"
                                             FontSize="13"
                                             Margin="0,5,0,15"/>
                                    <Button Content="Manage Builds"
                                           Style="{StaticResource ModernButton}"
                                           Width="140"
                                           Height="40"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Left"
                                           Click="NavigateToVersions"/>
                                </StackPanel>
                            </Border>

                          
                            <Border Grid.Column="1"
                                    Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="25"
                                    Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="CUSTOM BUILDS"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="11"
                                             Margin="0,0,0,15"/>
                                    <TextBlock x:Name="CustomBuildsCount"
                                             Text="0"
                                             Foreground="{StaticResource AccentSecondary}"
                                             FontSize="42"
                                             FontWeight="Light"/>
                                    <TextBlock Text="Drag and drop to add"
                                             Foreground="{StaticResource TextSecondary}"
                                             FontSize="13"
                                             Margin="0,5,0,15"/>
                                    <Border Background="{StaticResource BackgroundLight}"
                                            CornerRadius="8"
                                            Padding="10"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1">
                                        <TextBlock Text="📁 Drop ZIP files here"
                                                 Foreground="{StaticResource TextMuted}"
                                                 FontSize="12"
                                                 HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

           
                    <ScrollViewer x:Name="VersionsPage" 
                                  Visibility="Collapsed"
                                  Style="{StaticResource BlackScrollViewer}">
                        <StackPanel Margin="0,0,0,30">
                          
                            <Border Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="30"
                                    Margin="0,0,0,25"
                                    MinHeight="200">
                                <StackPanel>
                                    <TextBlock Text="STABLE BUILDS (AUTO-UPDATER)"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="12"
                                             Margin="0,0,0,25"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="60"
                                                Height="60"
                                                Background="{StaticResource BackgroundLight}"
                                                CornerRadius="30"
                                                Margin="0,0,20,0">
                                            <TextBlock Text="🔄" 
                                                     Foreground="{StaticResource AccentPrimary}"
                                                     FontSize="28"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="GitHub Auto-Updater"
                                                     Foreground="{StaticResource TextPrimary}"
                                                     FontSize="18"
                                                     FontWeight="SemiBold"/>
                                            <TextBlock x:Name="AutoUpdateStatus"
                                                     Text="No stable builds installed"
                                                     Foreground="{StaticResource TextSecondary}"
                                                     FontSize="13"
                                                     Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="Check for Updates"
                                                   Style="{StaticResource ModernButton}"
                                                   Width="140"
                                                   Height="45"
                                                   Margin="0,0,15,0"
                                                   Click="CheckForUpdates_Click"/>
                                            <Button Content="Install Latest"
                                                   Style="{StaticResource AccentButton}"
                                                   Width="120"
                                                   Height="45"
                                                   Click="ForceUpdate_Click"/>
                                        </StackPanel>
                                    </Grid>

                                   
                                    <Grid x:Name="AutoUpdateProgressSection" Margin="0,25,0,0" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="AutoUpdateStatusText"
                                                     Text="Downloading update..."
                                                     Foreground="{StaticResource TextSecondary}"
                                                     FontSize="13"/>
                                            <TextBlock x:Name="AutoUpdatePercentageText"
                                                     Grid.Column="1"
                                                     Text="0%"
                                                     Foreground="{StaticResource AccentPrimary}"
                                                     FontSize="13"
                                                     FontWeight="Bold"/>
                                        </Grid>

                                        <ProgressBar x:Name="AutoUpdateProgressBar"
                                                    Grid.Row="1"
                                                    Style="{StaticResource ModernProgressBar}"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Value="0"
                                                    Height="6"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                           
                            <Border x:Name="CustomBuildsDropZone"
                                    Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="30"
                                    Margin="0,0,0,25"
                                    AllowDrop="True"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    DragEnter="CustomBuildsDropZone_DragEnter"
                                    DragLeave="CustomBuildsDropZone_DragLeave"
                                    Drop="CustomBuildsDropZone_Drop">
                                <StackPanel>
                                    <TextBlock Text="CUSTOM BUILDS (DRAG and DROP)"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="12"
                                             Margin="0,0,0,20"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="60"
                                                Height="60"
                                                Background="{StaticResource BackgroundLight}"
                                                CornerRadius="30"
                                                Margin="0,0,20,0">
                                            <TextBlock Text="📦" 
                                                     Foreground="{StaticResource AccentSecondary}"
                                                     FontSize="28"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Add Custom Builds"
                                                     Foreground="{StaticResource TextPrimary}"
                                                     FontSize="18"
                                                     FontWeight="SemiBold"/>
                                            <TextBlock Text="Drag and drop ZIP files to install custom versions"
                                                     Foreground="{StaticResource TextSecondary}"
                                                     FontSize="13"
                                                     Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="{StaticResource BackgroundLight}"
                                                CornerRadius="8"
                                                Padding="15,10"
                                                BorderBrush="{StaticResource AccentSecondary}"
                                                BorderThickness="2">
                                            <TextBlock Text="DROP HERE"
                                                     Foreground="{StaticResource AccentSecondary}"
                                                     FontSize="14"
                                                     FontWeight="Bold"
                                                     HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                 
                                    <Grid x:Name="CustomProgressSection" Margin="0,20,0,0" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="CustomProgressStatusText"
                                                     Text="Extracting..."
                                                     Foreground="{StaticResource TextSecondary}"
                                                     FontSize="12"/>
                                            <TextBlock x:Name="CustomProgressPercentageText"
                                                     Grid.Column="1"
                                                     Text=""
                                                     Foreground="{StaticResource AccentPrimary}"
                                                     FontSize="12"
                                                     FontWeight="Bold"/>
                                        </Grid>

                                        <ProgressBar x:Name="CustomProgressBar"
                                                    Grid.Row="1"
                                                    Style="{StaticResource ModernProgressBar}"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Value="0"
                                                    IsIndeterminate="True"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                          
                            <Border Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="30"
                                    MinHeight="500">
                                <StackPanel>
                                    <TextBlock Text="ALL INSTALLED BUILDS"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="12"
                                             Margin="0,0,0,25"/>

                                    <ItemsControl x:Name="VersionsItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BackgroundLighter}"
                                                        CornerRadius="12"
                                                        Padding="25"
                                                        Margin="0,0,0,15">
                                                    <StackPanel>
                                                  
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <TextBlock Text="{Binding Icon}" FontSize="24" Foreground="{StaticResource AccentSecondary}" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                     
                                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
                                                            <Run Text="📁 Folder: " Foreground="{StaticResource AccentSecondary}"/>
                                                            <Run Text="{Binding FolderName}"/>
                                                        </TextBlock>

                                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,5,0,5">
                                                            <Run Text="📍 Path: " Foreground="{StaticResource AccentSecondary}"/>
                                                            <Run Text="{Binding FullPath}"/>
                                                        </TextBlock>

                                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
                                                            <Run Text="📅 Installed: " Foreground="{StaticResource AccentSecondary}"/>
                                                            <Run Text="{Binding InstallDate, StringFormat='MMMM dd, yyyy'}"/>
                                                        </TextBlock>

                                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,5,0,10">
                                                            <Run Text="⏱️ Playtime: " Foreground="{StaticResource AccentSecondary}"/>
                                                            <Run Text="{Binding PlayTimeDisplay}"/>
                                                        </TextBlock>

                                                     
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button Content="Launch"
                                                                   Style="{StaticResource ModernButton}"
                                                                   Width="100"
                                                                   Height="40"
                                                                   Margin="0,0,10,0"
                                                                   Tag="{Binding FolderName}"
                                                                   Click="LaunchVersion_Click"/>
                                                            <Button Content="Delete"
                                                                   Style="{StaticResource ModernButton}"
                                                                   Width="100"
                                                                   Height="40"
                                                                   Tag="{Binding FolderName}"
                                                                   Click="DeleteVersion_Click"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="NoVersionsText"
                                             Text="No builds installed. Drag and drop ZIP files to add custom builds."
                                             Foreground="{StaticResource TextSecondary}"
                                             FontSize="14"
                                             HorizontalAlignment="Center"
                                             Margin="0,50,0,50"
                                             Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="SettingsPage" 
                                  Visibility="Collapsed"
                                  Style="{StaticResource BlackScrollViewer}">
                        <StackPanel Margin="0,0,0,30">
                            
                            <Border Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="30"
                                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="PROFILE SETTINGS"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="12"
                                             Margin="0,0,0,25"/>

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                 Text="Username"
                                                 Foreground="{StaticResource TextSecondary}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"/>

                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="SettingsUsernameTextBox"
                                                    Grid.Column="0"
                                                    Style="{StaticResource ModernTextBox}"
                                                    Text="Player"
                                                    MaxLength="16"
                                                    Width="300"
                                                    Margin="0,0,15,0"/>

                                            <Button Grid.Column="1"
                                                   Content="Save"
                                                   Style="{StaticResource ModernButton}"
                                                   Width="100"
                                                   Height="40"
                                                   Click="SaveUsername_Click"/>
                                        </Grid>
                                    </Grid>

                                    <CheckBox x:Name="RememberUsernameCheckBox"
                                             Content="Remember username between sessions"
                                             Foreground="{StaticResource TextSecondary}"
                                             FontSize="14"
                                             IsChecked="True"
                                             Margin="150,0,0,0"
                                             Click="RememberUsername_Click"/>
                                </StackPanel>
                            </Border>

                            
                            <Border Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="30"
                                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="LAUNCHER SETTINGS"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="12"
                                             Margin="0,0,0,25"/>

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                 Text="Fullscreen mode"
                                                 Foreground="{StaticResource TextSecondary}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"/>

                                        <CheckBox x:Name="SettingsFullscreenCheckBox"
                                                 Grid.Column="1"
                                                 Content="Launch games in fullscreen by default"
                                                 Foreground="{StaticResource TextPrimary}"
                                                 FontSize="14"
                                                 Checked="FullscreenSetting_Changed"
                                                 Unchecked="FullscreenSetting_Changed"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                 Text="Close after launch"
                                                 Foreground="{StaticResource TextSecondary}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"/>

                                        <CheckBox x:Name="CloseAfterLaunchCheckBox"
                                                 Grid.Column="1"
                                                 Content="Close launcher when game starts"
                                                 Foreground="{StaticResource TextPrimary}"
                                                 FontSize="14"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            
                            <Border Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="30"
                                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="STORAGE"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="12"
                                             Margin="0,0,0,25"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                 Text="Builds folder"
                                                 Foreground="{StaticResource TextSecondary}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"/>

                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="BuildsPathTextBox"
                                                    Grid.Column="0"
                                                    Style="{StaticResource ModernTextBox}"
                                                    Text="Builds/"
                                                    IsReadOnly="True"
                                                    Margin="0,0,15,0"
                                                    Width="400"/>

                                            <Button Grid.Column="1"
                                                   Content="Open Folder"
                                                   Style="{StaticResource ModernButton}"
                                                   Width="120"
                                                   Height="40"
                                                   Click="OpenBuildsFolder_Click"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        
                            <Border Background="{StaticResource BackgroundMedium}"
                                    CornerRadius="12"
                                    Padding="30">
                                <StackPanel>
                                    <TextBlock Text="ABOUT"
                                             Foreground="{StaticResource TextMuted}"
                                             FontSize="12"
                                             Margin="0,0,0,15"/>

                                    <TextBlock Text="HyperLauncher"
                                             Foreground="{StaticResource TextPrimary}"
                                             FontSize="18"
                                             FontWeight="SemiBold"/>

                                    <TextBlock Text="made with 💞"
                                             Foreground="{StaticResource TextSecondary}"
                                             FontSize="14"
                                             Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>